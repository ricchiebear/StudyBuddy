extends layout

block content

  h2 Study Sessions
  p Find study partners or browse available study sessions.

  .listings-container
    each listing in listings
      .listing-card
        img.profile(src="/images/bookIcon.png")

        h3= listing.title

        p
          strong Module:
          | #{listing.module}

        p
          strong Location:
          | #{listing.location}

        p
          strong Start time:
          | #{listing.start_time}

        p
          strong Status:
          | #{listing.status}

        .join-container
          if requestedListingIds.includes(listing.listing_id)
            button.join-btn(disabled) Request Sent
          else
            form(method="POST" action=`/listings/${listing.listing_id}/join`)
              button.join-btn(type="submit") Request to Join